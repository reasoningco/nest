CURSOR_API_KEY=crsr_...
TARGET_REPO_URL=https://github.com/owner/repo
GITHUB_TOKEN=ghp_...
JIRA_BASE_URL=https://mycompany.atlassian.net
JIRA_EMAIL=me@mycompany.com
JIRA_API_TOKEN=...
JIRA_WEBHOOK_SECRET=...

# Optional
TRIGGER_LABEL=cursor
DEFAULT_MODEL=
POLL_INTERVAL_MS=60000
PR_TIMEOUT_MS=1800000
PORT=8787
DATA_DIR=./data
LOG_LEVEL=info
NODE_ENV=development

# Per-Jira-project repo routing (managed via SDM NEST → Routing).
# When set, /api/repo-mappings is enabled and webhook handlers consult
# the mappings table before falling back to TARGET_REPO_URL.
# BRIDGE_ADMIN_TOKEN must be at least 16 characters.
BRIDGE_ADMIN_TOKEN=
# Comma-separated browser origins allowed to call /api/repo-mappings
# directly (server-side proxies don't need this).
BRIDGE_CORS_ORIGINS=
