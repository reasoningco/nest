GITHUB_TOKEN=
JIRA_EMAIL=
JIRA_API_TOKEN=
OPENROUTER_API_KEY=
# Any OpenRouter model id works. Defaults are cheap/fast:
#   google/gemini-2.0-flash-lite-001
#   openai/gpt-4o-mini
#   google/gemini-flash-1.5-8b
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-001
# Optional — sent as HTTP-Referer to OpenRouter for attribution.
OPENROUTER_REFERRER=https://chaos.local

# Prisma resolves relative file: URLs against prisma/schema.prisma, so
# "../data/app.db" puts the DB at <project-root>/data/app.db.
# Shared access code. Unset → dashboard is open (dev convenience).
CHAOS_ACCESS_CODE=
# Gates the per-person LOC chart. Unset → chart is open (dev convenience).
# CHAOS_GRAPH_CODE=
# Bearer token for /api/claude-event ingest. Unset → /api/claude-event always
# 401s (telemetry off). Generate with: openssl rand -hex 32
CHAOS_TELEMETRY_TOKEN=

DATABASE_URL=file:../data/app.db
PORT=3000
HOST=0.0.0.0
